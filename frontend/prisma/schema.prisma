generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EuryxUser {
  id           String              @id
  email        String              @unique
  username     String              @unique
  passwordHash String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  decks        EuryxDeck[]
  settings     EuryxUserSettings?
  stats        EuryxUserStats?
  matches      EuryxMatchHistory[]
  regs         EuryxTournamentRegistration[]
}

model EuryxUserSettings {
  userId          String   @id
  user            EuryxUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  showChatInGame  Boolean   @default(false)
  preferredSeat   String    @default("auto")
  reduceMotion    Boolean   @default(false)
  activeDeckId    String?
  updatedAt       DateTime  @updatedAt
}

model EuryxUserStats {
  userId      String   @id
  user        EuryxUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  wins        Int      @default(0)
  losses      Int      @default(0)
  elo         Int      @default(1000)
  peakElo     Int      @default(1000)
  streak      Int      @default(0)
  bestStreak  Int      @default(0)
  totalDmg    Int      @default(0)
  totalKOs    Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model EuryxDeck {
  id        String           @id @default(cuid())
  name      String
  userId    String
  user      EuryxUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards     EuryxDeckCard[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model EuryxDeckCard {
  id          String   @id @default(cuid())
  deckId      String
  deck        EuryxDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  apiId       String
  name        String
  imageUrl    String?
  setCode     String?
  variant     String?
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
}

model EuryxMatchHistory {
  id            String   @id @default(cuid())
  userId        String
  user          EuryxUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  opponentId    String?
  opponentName  String
  result        String   // win | loss
  reason        String?  // prizes | concede
  turnCount     Int      @default(0)
  durationSec   Int      @default(0)
  damageDealt   Int      @default(0)
  knockouts     Int      @default(0)
  eloBefore     Int      @default(1000)
  eloAfter      Int      @default(1000)
  eloDelta      Int      @default(0)
  roomId        String
  endedAt       DateTime @default(now())

  @@index([userId, endedAt])
}

model EuryxTournament {
  id             String   @id @default(cuid())
  name           String
  format         String
  status         String   // upcoming | registration | live | finished
  startsAt       DateTime
  registeredCnt  Int      @default(0)
  capacity       Int      @default(64)
  prizePool      String?
  region         String?
  bannerImageUrl String?
  description    String?
  createdAt      DateTime @default(now())
  registrations  EuryxTournamentRegistration[]
  matches        EuryxTournamentMatch[]
}

model EuryxTournamentRegistration {
  id            String   @id @default(cuid())
  tournamentId  String
  tournament    EuryxTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId        String
  user          EuryxUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  username      String
  seed          Int?
  eliminated    Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@unique([tournamentId, userId])
}

model EuryxTournamentMatch {
  id            String   @id @default(cuid())
  tournamentId  String
  tournament    EuryxTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round         Int
  position      Int       // bracket slot
  player1Id     String?
  player1Name   String?
  player2Id     String?
  player2Name   String?
  winnerId      String?
  scheduledAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([tournamentId, round])
}
